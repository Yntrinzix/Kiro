{
  "version": "1.0.0",
  "enabled": true,
  "name": "Trigger GitHub Actions CI Validation",
  "description": "Triggered once a task's code changes are finalized. This hook initiates a call to the GitHub API (specifically the workflow_dispatch for ci.yml). It prevents the agent from marking a task as \"Done\" until the CI suite returns a success state. If the CI fails, the hook should feed the error logs back to the agent as a new sub-task to \"Self-Heal\" the code.",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "bun install --frozen-lockfile && bun run biome format --write . && bun turbo typecheck && bun run check:biome && bun turbo test:unit"
  },
  "workspaceFolderName": "Ubiquity-WebApps",
  "shortName": "trigger-github-actions-ci-validation"
}