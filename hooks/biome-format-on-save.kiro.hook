{
  "enabled": true,
  "name": "Biome Format on Save",
  "description": "Automatically formats all files with Biome when a file is saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.tsx",
      "*.js",
      "*.jsx",
      "*.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "bunx biome format --write .",
    "timeout": 60
  }
}