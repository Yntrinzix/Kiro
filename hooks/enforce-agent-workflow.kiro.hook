{
  "enabled": true,
  "name": "Enforce Agent Workflow",
  "description": "Before any write operation to source code files, remind the agent to delegate to the appropriate specialized agent (@frontend, @tester, @protobuf-engineer) per .kiro/steering/agent-workflow.md instead of making changes directly.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "STOP. Check .kiro/steering/agent-workflow.md before writing code. You MUST delegate code changes to the appropriate specialized agent (@frontend for TS/React, @tester for tests, @protobuf-engineer for proto files). You are the orchestrator — you coordinate, you do NOT write code directly. Only proceed if this write is to a non-code file (steering, config, spec docs) or if you are currently executing inside a subagent invocation."
  }
}